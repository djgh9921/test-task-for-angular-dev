{
  "extends": "../../tsconfig.base.json",
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "module": "es2020",
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "noImplicitAny": true,
    "target": "ES2022",
    "typeRoots": ["../../node_modules/@types"],
    "lib": ["es2018", "dom"],
    "baseUrl": "./",
    "paths": {
      "@app/*": ["src/app/*"],
      "@env/*": ["src/environments/*"],
      "@core": ["../../libs/core/src/index.ts"],
      "@core/*": ["../../libs/core/src/lib/*"],
      "@shared": ["../../libs/shared/src/index.ts"],
      "@shared/*": ["../../libs/shared/src/lib/*"],
      "@auth": ["../../libs/auth/src/index.ts"],
      "@auth/*": ["../../libs/auth/src/lib/*"],
      "@i18n": ["../../libs/i18n/src/index.ts"],
      "@i18n/*": ["../../libs/i18n/src/lib/*"],
      "@shell": ["../../libs/shell/src/index.ts"],
      "@shell/*": ["../../libs/shell/src/lib/*"],
      "@weather": ["../../libs/weather/src/index.ts"],
      "@weather/state": ["../../libs/weather/state/src/index.ts"],
      "@weather/ui": ["../../libs/weather/ui/src/index.ts"],
      "@block-builder": ["../../libs/block-builder/src/index.ts"]
    },
    "useDefineForClassFields": false
  },
  "angularCompilerOptions": {
    "fullTemplateTypeCheck": true,
    "strictInjectionParameters": true,
    "preserveWhitespaces": true
  }
}
